import React, { useState, useRef } from 'react';
import { ChevronDown } from 'lucide-react';
import { Question, Subpattern } from '@/types';

interface AnimatedSubpatternProps {
  subpattern: Subpattern;
  subpatternIndex: number;
  renderQuestion: (question: Question, index: number, prefix: string) => React.ReactNode;
}

const AnimatedSubpattern = ({ subpattern, subpatternIndex, renderQuestion }: AnimatedSubpatternProps) => {
  const [isExpanded, setIsExpanded] = useState(false);
  const contentRef = useRef<HTMLDivElement>(null);
  const [contentHeight, setContentHeight] = useState<number>(0);

  const toggleExpand = () => {
    if (contentRef.current) {
      // Get the scroll height before collapse to ensure smooth animation
      setContentHeight(isExpanded ? 0 : contentRef.current.scrollHeight);
    }
    setIsExpanded(!isExpanded);
  };

  return (
    <div className="space-y-2">
      <div
        onClick={toggleExpand}
        className="subpattern-header bg-white dark:bg-gray-800 rounded-xl p-6 shadow-lg 
                 border border-purple-100 dark:border-purple-900 transition-all duration-300 
                 hover:shadow-xl cursor-pointer select-none"
      >
        <div className="flex items-center justify-between">
          <h2 className="text-2xl font-bold text-gray-800 dark:text-gray-100">
            {subpattern.title}
          </h2>
          <ChevronDown 
            className={`w-6 h-6 text-gray-600 dark:text-gray-400 transition-transform duration-300 ease-in-out ${
              isExpanded ? 'transform rotate-180' : ''
            }`}
          />
        </div>
      </div>

      <div
        className="overflow-hidden transition-[height] duration-300 ease-in-out"
        style={{ height: isExpanded ? contentHeight : 0 }}
      >
        <div ref={contentRef} className="space-y-4 pt-2">
          {subpattern.questions.map((question, index) => 
            renderQuestion(question, index, `${subpatternIndex + 1}.`)
          )}
        </div>
      </div>
    </div>
  );
};

export default AnimatedSubpattern;
